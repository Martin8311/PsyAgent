# 复制本文件为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会进仓库）。
# docker compose 会自动读取同目录下的 .env。

# MySQL root 密码（同时用于初始化 MySQL 容器与应用连接）
MYSQL_PASSWORD=change-me

# Redis 密码
REDIS_PASSWORD=change-me

# RabbitMQ（不填则用默认 guest/guest）
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# QQ 邮件高危预警（可留空，留空则不发邮件，应用仍能启动）
MAIL_USERNAME=
MAIL_PASSWORD=
ADMIN_MAIL=
